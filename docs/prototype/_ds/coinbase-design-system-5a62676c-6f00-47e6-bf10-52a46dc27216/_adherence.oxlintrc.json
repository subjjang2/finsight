{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/cards/**",
              "components/core/**",
              "components/forms/**",
              "components/navigation/**",
              "components/trading/**",
              "ui_kits/marketing-website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Inter, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='AssetIcon'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|alt|children|size|plate|style|key|ref|className|style|children)$/]",
        "message": "<AssetIcon> doesn't accept that prop. Declared props: src, alt, children, size, plate, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='AssetRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|name|ticker|price|change|divider|onClick|style|key|ref|className|style|children)$/]",
        "message": "<AssetRow> doesn't accept that prop. Declared props: icon, name, ticker, price, change, divider, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:default|dark|up|down)$/]",
        "message": "<Badge> tone must be one of 'default' | 'dark' | 'up' | 'down'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|disabled|onClick|href|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, disabled, onClick, href, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|secondary-dark|outline-dark|tertiary)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'secondary-dark' | 'outline-dark' | 'tertiary'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|lg)$/]",
        "message": "<Button> size must be one of 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|padding|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, variant, padding, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:hairline|flat|shadow|dark|dark-elevated)$/]",
        "message": "<Card> variant must be one of 'hairline' | 'flat' | 'shadow' | 'dark' | 'dark-elevated'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FeatureCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:glyph|title|children|linkLabel|href|variant|style|key|ref|className|style|children)$/]",
        "message": "<FeatureCard> doesn't accept that prop. Declared props: glyph, title, children, linkLabel, href, variant, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FeatureCard'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:hairline|flat|shadow|dark|dark-elevated)$/]",
        "message": "<FeatureCard> variant must be one of 'hairline' | 'flat' | 'shadow' | 'dark' | 'dark-elevated'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, error."
      },
      {
        "selector": "JSXOpeningElement[name.name='PriceCell'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|direction|showSign|style|key|ref|className|style|children)$/]",
        "message": "<PriceCell> doesn't accept that prop. Declared props: value, direction, showSign, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PriceCell'] > JSXAttribute[name.name='direction'] > Literal[value!=/^(?:up|down)$/]",
        "message": "<PriceCell> direction must be one of 'up' | 'down'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PricingTier'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|price|period|features|ctaLabel|featured|onSelect|style|key|ref|className|style|children)$/]",
        "message": "<PricingTier> doesn't accept that prop. Declared props: name, price, period, features, ctaLabel, featured, onSelect, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProductUICard'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|rotate|padding|style|key|ref|className|style|children)$/]",
        "message": "<ProductUICard> doesn't accept that prop. Declared props: children, tone, rotate, padding, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProductUICard'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:dark|light)$/]",
        "message": "<ProductUICard> tone must be one of 'dark' | 'light'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SearchPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:placeholder|value|onChange|key|ref|className|style|children)$/]",
        "message": "<SearchPill> doesn't accept that prop. Declared props: placeholder, value, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='TopNav'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|onDark|style|key|ref|className|style|children)$/]",
        "message": "<TopNav> doesn't accept that prop. Declared props: items, onDark, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Wordmark'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|symbolOnly|height|style|key|ref|className|style|children)$/]",
        "message": "<Wordmark> doesn't accept that prop. Declared props: variant, symbolOnly, height, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Wordmark'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:dark|light)$/]",
        "message": "<Wordmark> variant must be one of 'dark' | 'light'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
