ANTHROPIC_API_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# 절대 URL(OAuth 콜백 redirectTo 구성용). 로컬은 http://localhost:3000, 프로덕션은 배포 도메인
NEXT_PUBLIC_SITE_URL=
# PostHog product analytics (클라이언트 노출 OK — 공개 키). host는 US 클라우드.
# 클라이언트는 next.config.ts의 /ingest reverse proxy로 same-origin 전송한다.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POLAR_ACCESS_TOKEN=
POLAR_PRO_PRODUCT_ID=
POLAR_WEBHOOK_SECRET=
# Sandbox 테스트 시에만 설정. 기본값은 프로덕션(https://api.polar.sh)
# POLAR_API_BASE=https://sandbox-api.polar.sh
